# --- Сервер ---
PORT=8080
# CORS: origin фронта в деве. В проде фронт раздаётся статикой с того же домена.
FRONTEND_ORIGIN=http://localhost:5173
# Путь к собранному фронту (frontend/dist). Если задан — бэк раздаёт статику.
STATIC_DIR=

# --- Dasha BlackBox ---
# API-ключ. ДЕРЖАТЬ ТОЛЬКО НА СЕРВЕРЕ. Без него сессии отдаются в режиме simulator.
DASHA_API_KEY=
DASHA_BASE_URL=https://blackbox.dasha.ai
# Web Integration ID на каждую нишу (создаются в дашборде Dasha).
DASHA_INTEGRATION_DENTAL=
DASHA_INTEGRATION_AUTO=
DASHA_INTEGRATION_MEAT=
DASHA_INTEGRATION_SALON=
DASHA_INTEGRATION_FOOD=
# Срок жизни выдаваемого браузеру токена, секунд.
DASHA_TOKEN_TTL_SECONDS=900

# --- Voximplant (телефония, опционально) ---
VOXIMPLANT_ACCOUNT_ID=
VOXIMPLANT_API_KEY=

# --- Лимиты публичного режима ---
# Кап минут разговора на одну сессию.
SESSION_MINUTE_CAP=3
# Макс. сессий с одного IP за окно.
IP_MAX_SESSIONS=5
IP_WINDOW_MINUTES=60
# Ключ презентер-режима (?presenter=KEY снимает лимиты).
PRESENTER_KEY=change-me

# --- Supabase (лиды публичного режима) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_LEADS_TABLE=sandbox_leads
